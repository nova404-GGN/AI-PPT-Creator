    <script>
        (function() {
            const btn = document.getElementById('langToggle');
            const zhContent = document.querySelector('.lang-zh');
            const enContent = document.querySelector('.lang-en');
            const btnZh = btn.querySelector('.btn-zh');
            const btnEn = btn.querySelector('.btn-en');

            // 初始状态：中文显示
            let currentLang = 'zh';

            function switchLang(lang) {
                if (lang === 'en') {
                    zhContent.classList.remove('active');
                    enContent.classList.add('active');
                    btnZh.style.display = 'none';
                    btnEn.style.display = 'inline';
                    currentLang = 'en';
                } else {
                    enContent.classList.remove('active');
                    zhContent.classList.add('active');
                    btnEn.style.display = 'none';
                    btnZh.style.display = 'inline';
                    currentLang = 'zh';
                }
            }

            btn.addEventListener('click', function() {
                if (currentLang === 'zh') {
                    switchLang('en');
                } else {
                    switchLang('zh');
                }
            });
        })();
    </script>
